# IRIS Client
IRIS_CLIENT=EARTHSCOPE
NETWORK=IU
STATION=ANMO
LOCATION=00
CHANNEL=HHZ

# Download parameters
START_DATE=2023-01-01
END_DATE=2024-12-31
MIN_MAGNITUDE=4.0
MAX_MAGNITUDE=7.0
EVENT_LIMIT=300
WAVEFORM_PRE_SECONDS=60
WAVEFORM_POST_SECONDS=240
NOISE_COUNT=200

# Paths
DATA_DIR=data
EARTHQUAKE_DIR=data/earthquake
NOISE_DIR=data/noise
CATALOG_FILE=earthquake_catalog.xml
FEATURES_FILE=features.csv
VISUALIZATION_FILE=milestone1_visualization.pdf

# Feature extraction
WAVEFORM_LENGTH=6000
PCA_COMPONENTS=50
